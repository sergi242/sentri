    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Règle : Si PAS d'alerte, on affiche le modal de nouveau dossier immédiatement
            @if(!session('watchlist_danger'))
                $('#postCreateModal').modal({
                    backdrop: 'static',
                    keyboard: false
                });
            @endif
        });

        // Fonction pour fermer l'alerte et ENCHAÎNER sur le modal de nouveau dossier
        function dismissSecurityAlert() {
            // 1. Masquer les éléments d'alerte
            document.getElementById('danger-border').style.display = 'none';
            document.getElementById('securityAlertModal').style.display = 'none';
            
            // 2. Arrêter le son
            var audio = document.getElementById('alert-sound');
            if(audio) audio.pause();
            
            // 3. Afficher ENFIN le modal pour choisir de faire un nouveau dossier
            $('#postCreateModal').modal({
                backdrop: 'static',
                keyboard: false
            });
        }
    </script>

